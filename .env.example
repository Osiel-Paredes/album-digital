# Copia este archivo como ".env" y llena tus datos reales.
# NUNCA subas el archivo ".env" a Git (ya está excluido en .gitignore).

# Cadena de conexión de tu base de datos PostgreSQL (Railway, Render, Supabase...)
# La encuentras en el panel de tu servicio de Postgres, sección "Connect".
DATABASE_URL=postgresql://usuario:contrasena@host:5432/nombre_basedatos

# Opcional: carpeta donde guardar las fotos subidas.
# Déjalo vacío para usar la carpeta local public/uploads.
# En producción, apunta a tu disco persistente (ej. /data/uploads).
UPLOADS_DIR=
